{
  "name": "nc-fullstack",
  "version": "1.0.0",
  "description": "NC Knowledge Graph System",
  "scripts": {
    "dev": "concurrently -n BACKEND,FRONTEND -c blue,green \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && .\\..\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --host 0.0.0.0 --port 8001 --reload",
    "frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
